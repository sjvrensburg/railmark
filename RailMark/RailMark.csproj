<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>railmark</ToolCommandName>
    <PackageId>RailMark</PackageId>
    <Version>0.6.1</Version>
    <Description>Convert any PDF to structured Markdown — layout-aware export plus RailReader2 annotation extraction. Standalone, no external CLI required.</Description>
    <AssemblyName>railmark</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="RailMark.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="RailReader.Export" Version="0.31.0" />
    <PackageReference Include="RailReader.Renderer.Skia" Version="0.31.0" />
    <PackageReference Include="RailReader.Core.Analysis" Version="0.31.0" />
  </ItemGroup>

</Project>
